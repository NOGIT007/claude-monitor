{
  "name": "claude-monitoring",
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "build": "bun build --compile ./src/server.ts --outfile ./claude-monitor",
    "start": "./scripts/start.sh",
    "stop": "./scripts/stop.sh",
    "backfill": "bun run scripts/backfill.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "bun-types": "^1.2.9",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.58.1"
  }
}
